# ===================================
# SNMP MIB Explorer Pro 配置文件
# 复制此文件为 .env 并修改配置
# ===================================

# 服务端口
BACKEND_PORT=8080
FRONTEND_PORT=3000

# 后端配置
GIN_MODE=release          # debug / release
DATA_DIR=./data           # 数据存储目录

# 前端 API 地址 (Docker 环境无需修改)
VITE_API_BASE_URL=/api

# Docker 镜像加速 (国内用户建议开启)
# DOCKER_REGISTRY_MIRROR=https://docker.1ms.run

# 时区
TZ=Asia/Shanghai
